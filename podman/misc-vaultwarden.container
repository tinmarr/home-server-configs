[Unit]
Description=Vaultwarden Password Manager
After=network-online.target
Wants=network-online.target

[Container]
Image=vaultwarden/server:latest
AutoUpdate=registry
PublishPort=127.0.0.1:9090:80
Volume=%h/vw-data:/data
User=1000:1000
Label=homepage.group=Apps
Label=homepage.name=Vaultwarden
Label=homepage.href=https://vw.tinmarr.com
Label=homepage.icon=vaultwarden

[Service]
Restart=unless-stopped

[Install]
WantedBy=multi-user.target
